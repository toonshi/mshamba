{
  "canisters": {
    "token_factory": {
      "type": "motoko",
      "main": "src/factory/main.mo"
    },
    "mshamba_backend": {
      "main": "src/mshamba_backend/main.mo",
      "type": "motoko",
      "canister_id": "pwj2z-kaaaa-aaaac-a4bea-cai",
      "controllers": [
        "4qesy-eqkkq-3gwkk-oyyov-ivmyr-tfav4-w7x7b-2qi7k-hl4yb-bz6im-7ae"
      ]
    },
    "mshamba_frontend": {
      "type": "assets",
      "source": ["src/mshamba_frontend/dist"],
      "build": "cd src/mshamba_frontend && npm install && npm run build",
      "dependencies": [
        "mshamba_backend"
      ]
    },
    "farm1_ledger": {
      "type": "custom",
      "candid": "wasm/ledger.did",
      "wasm": "wasm/ic-icrc1-ledger.wasm",
      "controllers": [
        "nebfo-nlhqi-oqa3e-kgpja-bmkud-iymq2-aqnjc-wfigz-hclu6-npvgz-tqe"
      ]
    },
    "farm2_ledger": {
      "type": "custom",
      "candid": "wasm/ledger.did",
      "wasm": "wasm/ic-icrc1-ledger.wasm",
      "controllers": [
        "nebfo-nlhqi-oqa3e-kgpja-bmkud-iymq2-aqnjc-wfigz-hclu6-npvgz-tqe"
      ]
    },
    "farm3_ledger": {
      "type": "custom",
      "candid": "wasm/ledger.did",
      "wasm": "wasm/ic-icrc1-ledger.wasm",
      "controllers": [
        "nebfo-nlhqi-oqa3e-kgpja-bmkud-iymq2-aqnjc-wfigz-hclu6-npvgz-tqe"
      ]
    },
    "farm4_ledger": {
      "type": "custom",
      "candid": "wasm/ledger.did",
      "wasm": "wasm/ic-icrc1-ledger.wasm",
      "controllers": [
        "nebfo-nlhqi-oqa3e-kgpja-bmkud-iymq2-aqnjc-wfigz-hclu6-npvgz-tqe"
      ]
    },

    "farm1_index": {
      "type": "custom",
      "wasm": "wasm/ic-icrc1-index-ng.wasm",
      "candid": "wasm/index-ng.did",
      "init_arg": "(opt variant { Init = record {\n        ledger_id = principal \"uxrrr-q7777-77774-qaaaa-cai\"
      } })",
      "controllers": [
        "nebfo-nlhqi-oqa3e-kgpja-bmkud-iymq2-aqnjc-wfigz-hclu6-npvgz-tqe"
      ]
    },

    "mshamba_assets": {
      "type": "motoko",
      "main": "src/mshamba_assets/main.mo"
    },
    "Filevault": {
      "type": "motoko",
      "main": "FileVault/backend/app.mo"
    }
  },

  "defaults": {
    "build": {
      "args": "",
      "packtool": ""
    }
  },

  "output_env_file": ".env",

  "networks": {
    "ic": {
      "providers": [
        "https://mainnet.dfinity.network"
      ],
      "type": "persistent"
    }
  },

  "version": 1,

  "declarations": {
    "output": "src/declarations",
    "node_compatibility": true
  }
}